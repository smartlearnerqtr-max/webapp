FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-very-long-secret-string
JWT_SECRET_KEY=change-me-to-a-very-long-jwt-secret
ENCRYPTION_SECRET=change-me-to-a-very-long-encryption-secret
# Local dev default uses SQLite. Render se tu inject DATABASE_URL Postgres qua render.yaml.
DATABASE_URL=sqlite:///instance/dev.db
CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
GEMINI_MODEL_NAME=gemini-2.5-flash
# Option 1: dat nhieu key tren mot dong, cach nhau boi dau phay.
GEMINI_API_KEYS=
# Option 2: dat tung key rieng. He thong se gop va xoay vong tu dong.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=
